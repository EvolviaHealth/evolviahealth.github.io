# ─────────────────────────────────────────────────────────────────────────────
# EvolvIA Health — variables d'environnement
# Copier en .env.local (dev) et renseigner sur Vercel (prod).
# Le formulaire de RDV fonctionne SANS ces clés (fallback mailto). Les clés
# activent la confirmation automatique par email + le lien Google Meet.
# ─────────────────────────────────────────────────────────────────────────────

# --- Emails (Resend) — https://resend.com ---
RESEND_API_KEY=
BOOKING_FROM_EMAIL="EvolvIA Health <evolviahealth@outlook.fr>"
# Adresse qui reçoit les notifications de nouveaux RDV (boîte de Cassiopée)
BOOKING_OWNER_EMAIL=
CONTACT_EMAIL=evolviahealth@outlook.fr

# --- Google Calendar + Google Meet (OAuth2) ---
# Console Google Cloud → API Calendar activée → identifiants OAuth2.
# Générer un refresh_token une fois (voir README.md, guide pas à pas).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# --- VRAI CALENDRIER DE RDV : Cal.com (recommandé, façon Doctolib) ---
# Coller ici le lien d'événement Cal.com de Cassiopée, au format
# « identifiant/type-evenement » (ex. evolvia-health/consultation).
# Cal.com gère alors EN TEMPS RÉEL : créneaux réellement libres affichés au
# visiteur, anti double-réservation, sync Google Agenda 2 sens, emails +
# rappels + lien visio auto, et tableau de bord live pour Cassiopée.
# (Voir README.md, « Activer le calendrier Cal.com ».)
NEXT_PUBLIC_CAL_LINK=

# --- FORMULAIRE DE CONTACT : Web3Forms (envoi email réel, sans serveur, gratuit) ---
# Clé d'accès gratuite créée sur https://web3forms.com avec l'EMAIL qui doit
# recevoir les demandes (la boîte de Cassiopée). Chaque envoi du formulaire part
# alors directement par email chez Cassiopée. Sans cette clé, le formulaire
# bascule sur un mailto pré-rempli. (Voir README.md, « Activer le formulaire ».)
NEXT_PUBLIC_WEB3FORMS_KEY=

# --- VRAIE prise de rendez-vous : Google Appointment Scheduling ---
# Coller ici l'URL de la page de réservation de Google Agenda de Cassiopée.
# Google gère alors : créneaux réels, places prises, lien Google Meet auto et
# email de confirmation. (Voir README.md, « Activer la vraie prise de RDV Google ».)
NEXT_PUBLIC_GCAL_BOOKING_URL=

# --- Optionnel : surcharger l'URL de l'endpoint de réservation côté client ---
# NEXT_PUBLIC_BOOKING_ENDPOINT=/api/booking

# --- Sanity (CMS, optionnel, déjà présent dans le projet) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
